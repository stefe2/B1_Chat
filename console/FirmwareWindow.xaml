<Window x:Class="b1_chat_console.FirmwareWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:b1_chat_console.Views"
        Title="Firmware — B1 Chat" Height="820" Width="480"
        Icon="Assets/AppIcon.ico"
        Background="{StaticResource PageBackgroundBrush}">
    <Grid>
        <Rectangle Fill="{StaticResource NoiseTileBrush}" IsHitTestVisible="False" />
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <views:FirmwareCardView Margin="16" />
        </ScrollViewer>
    </Grid>
</Window>
