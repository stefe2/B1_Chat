<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Palette ported from wwwroot/index.html's CSS custom properties (dark brushed-metal theme). -->

    <SolidColorBrush x:Key="BgBrush" Color="#43464C" />
    <SolidColorBrush x:Key="Bg2Brush" Color="#3A3D42" />
    <SolidColorBrush x:Key="PanelBrush" Color="#4C4F56" />
    <SolidColorBrush x:Key="PanelHiBrush" Color="#5A5E66" />
    <SolidColorBrush x:Key="RecessBrush" Color="#2E3034" />
    <SolidColorBrush x:Key="Recess2Brush" Color="#26282B" />

    <SolidColorBrush x:Key="BorderHiBrush" Color="#38FFFFFF" />
    <SolidColorBrush x:Key="BorderLoBrush" Color="#73000000" />

    <SolidColorBrush x:Key="TextBrush" Color="#ECEEEF" />
    <SolidColorBrush x:Key="TextStrongBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="MutedBrush" Color="#A9ADB3" />
    <SolidColorBrush x:Key="Muted2Brush" Color="#797D84" />

    <SolidColorBrush x:Key="AccentBrush" Color="#FF9D2E" />
    <SolidColorBrush x:Key="AccentDimBrush" Color="#29FF9D2E" />

    <SolidColorBrush x:Key="OkBrush" Color="#3DDC84" />
    <SolidColorBrush x:Key="OkDimBrush" Color="#293DDC84" />
    <SolidColorBrush x:Key="WarnBrush" Color="#FFCC4D" />
    <SolidColorBrush x:Key="WarnDimBrush" Color="#29FFCC4D" />
    <SolidColorBrush x:Key="BadBrush" Color="#FF5B52" />
    <SolidColorBrush x:Key="BadDimBrush" Color="#29FF5B52" />

    <FontFamily x:Key="MonoFont">Consolas</FontFamily>
    <FontFamily x:Key="SansFont">Segoe UI</FontFamily>

    <LinearGradientBrush x:Key="PageBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#43464C" Offset="0" />
        <GradientStop Color="#3A3D42" Offset="1" />
    </LinearGradientBrush>

    <!-- Two-tone diagonal bevel (equivalent to the CSS border-hi/border-lo duo, applied as a
         single 135deg gradient border: light top-left, dark bottom-right). -->
    <LinearGradientBrush x:Key="BevelBorderBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#38FFFFFF" Offset="0" />
        <GradientStop Color="#15FFFFFF" Offset="0.4" />
        <GradientStop Color="#73000000" Offset="1" />
    </LinearGradientBrush>

    <!-- Higher-contrast "brushed metal" button gradient (sharp highlight on top, shadow at the bottom). -->
    <LinearGradientBrush x:Key="ButtonBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#6A6F79" Offset="0" />
        <GradientStop Color="#5A5E66" Offset="0.15" />
        <GradientStop Color="#484B52" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="ButtonHoverBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#787E89" Offset="0" />
        <GradientStop Color="#666B74" Offset="0.15" />
        <GradientStop Color="#54585F" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="ButtonPressedBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#34363A" Offset="0" />
        <GradientStop Color="#3E4146" Offset="0.5" />
        <GradientStop Color="#484B52" Offset="1" />
    </LinearGradientBrush>

    <!-- Diagonal noise texture (approximates index.html's 115deg repeating-linear-gradient),
         tiled as a DrawingBrush to stay lightweight. -->
    <DrawingBrush x:Key="NoiseTileBrush" TileMode="Tile" Viewport="0,0,4,4" ViewportUnits="Absolute" Opacity="0.05">
        <DrawingBrush.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="#FFFFFF">
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="0,0,4,4" />
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing Brush="#000000">
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <RectangleGeometry Rect="0,0,2,4" />
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingBrush.Drawing>
    </DrawingBrush>

    <RadialGradientBrush x:Key="LedOffBrush" Center="0.35,0.35" GradientOrigin="0.35,0.35" RadiusX="0.8" RadiusY="0.8">
        <GradientStop Color="#FF7A6E" Offset="0" />
        <GradientStop Color="#B23A32" Offset="1" />
    </RadialGradientBrush>
    <RadialGradientBrush x:Key="LedOnBrush" Center="0.35,0.35" GradientOrigin="0.35,0.35" RadiusX="0.8" RadiusY="0.8">
        <GradientStop Color="#8CF5B8" Offset="0" />
        <GradientStop Color="#2CB86C" Offset="1" />
    </RadialGradientBrush>

    <!-- Primary action button (Connect/Disconnect) in accent orange, HTML-CTA-style. -->
    <LinearGradientBrush x:Key="AccentButtonBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FFB35C" Offset="0" />
        <GradientStop Color="#FF9D2E" Offset="0.25" />
        <GradientStop Color="#E08620" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="AccentButtonHoverBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FFC176" Offset="0" />
        <GradientStop Color="#FFAA47" Offset="0.25" />
        <GradientStop Color="#EF9330" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="AccentButtonPressedBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#D67418" Offset="0" />
        <GradientStop Color="#E08620" Offset="0.5" />
        <GradientStop Color="#EF9330" Offset="1" />
    </LinearGradientBrush>

    <!-- Mesh topology graph nodes: glossy spheres, master in accent color, slave in neutral metal. -->
    <RadialGradientBrush x:Key="MeshMasterNodeBrush" Center="0.35,0.3" GradientOrigin="0.35,0.3" RadiusX="0.9" RadiusY="0.9">
        <GradientStop Color="#FFC176" Offset="0" />
        <GradientStop Color="#FF9D2E" Offset="0.55" />
        <GradientStop Color="#C96F16" Offset="1" />
    </RadialGradientBrush>
    <RadialGradientBrush x:Key="MeshSlaveNodeBrush" Center="0.35,0.3" GradientOrigin="0.35,0.3" RadiusX="0.9" RadiusY="0.9">
        <GradientStop Color="#8B909A" Offset="0" />
        <GradientStop Color="#5A5E66" Offset="0.6" />
        <GradientStop Color="#3E4146" Offset="1" />
    </RadialGradientBrush>

</ResourceDictionary>
