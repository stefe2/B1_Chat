<Window x:Class="b1_chat_console.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:b1_chat_console"
        xmlns:views="clr-namespace:b1_chat_console.Views"
        mc:Ignorable="d"
        Title="B1 Chat — Console de supervision" Height="900" Width="1500"
        Background="{StaticResource PageBackgroundBrush}">
    <Grid>
        <!-- Texture de bruit diagonale par-dessus le fond, sur toute la fenetre. -->
        <Rectangle Fill="{StaticResource NoiseTileBrush}" IsHitTestVisible="False" />

        <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- En-tete : logo + titre, statut/port, commit/revert -->
        <Border Grid.Row="0" Background="{StaticResource Bg2Brush}" BorderBrush="{StaticResource BevelBorderBrush}" BorderThickness="0,0,0,1.5" Padding="18,12">
            <Border.Effect>
                <DropShadowEffect Color="Black" Direction="270" ShadowDepth="3" BlurRadius="8" Opacity="0.4" />
            </Border.Effect>
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <Border Style="{StaticResource AppLogoStyle}" Margin="0,0,10,0">
                        <Canvas Width="20" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Rectangle Canvas.Left="9" Canvas.Top="0" Width="2" Height="4" Fill="#2A1B0A" />
                            <Ellipse Canvas.Left="8" Canvas.Top="0" Width="4" Height="4" Fill="#2A1B0A" />
                            <Rectangle Canvas.Left="0" Canvas.Top="4" Width="20" Height="12" RadiusX="4" RadiusY="4" Fill="#2A1B0A" />
                            <Ellipse Canvas.Left="4" Canvas.Top="8" Width="4" Height="4" Fill="#FF9D2E" />
                            <Ellipse Canvas.Left="12" Canvas.Top="8" Width="4" Height="4" Fill="#FF9D2E" />
                        </Canvas>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="B1 CHAT" Style="{StaticResource PageTitleStyle}" />
                        <TextBlock Text="{Binding VersionSubtitle}" Style="{StaticResource MetaTextStyle}" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Border Style="{Binding ShowCommitUi, Converter={StaticResource BoolToStyleConv}, ConverterParameter='HaloBadgeWarnStyle|HaloBadgeBaseStyle'}"
                            Visibility="{Binding ShowCommitUi, Converter={StaticResource BoolToVisConv}}" Margin="0,0,8,0" VerticalAlignment="Center">
                        <TextBlock Text="● non enregistré" FontSize="11" />
                    </Border>
                    <Button Content="Enregistrer" Style="{StaticResource MiniButtonStyle}" Command="{Binding CommitChangesCommand}"
                            Visibility="{Binding ShowCommitUi, Converter={StaticResource BoolToVisConv}}" Margin="0,0,4,0" />
                    <Button Content="Annuler" Style="{StaticResource MiniButtonStyle}" Command="{Binding RevertChangesCommand}"
                            Visibility="{Binding ShowCommitUi, Converter={StaticResource BoolToVisConv}}" Margin="0,0,20,0" />

                    <Button Content="Firmware…" Style="{StaticResource MiniButtonStyle}" Click="OpenFirmwareWindow_Click"
                            Margin="0,0,16,0" VerticalAlignment="Center" ToolTip="Ouvrir la fenêtre de flash firmware et des mises à jour" />

                    <Border Style="{StaticResource HeaderPillStyle}" Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Style="{Binding Connected, Converter={StaticResource BoolToStyleConv}, ConverterParameter='LedDotOnStyle|LedDotOffStyle'}"
                                     VerticalAlignment="Center" Margin="0,0,7,0" />
                            <TextBlock Text="{Binding ConnectionStatusText}" Foreground="{StaticResource TextBrush}" FontSize="11" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <ComboBox Width="100" Style="{StaticResource DarkComboBoxStyle}" ItemsSource="{Binding AvailablePorts}" SelectedItem="{Binding SelectedPort}" Margin="0,0,6,0" />
                    <Button Content="Rescan" Style="{StaticResource MiniButtonStyle}" Command="{Binding RefreshPortsCommand}" Margin="0,0,8,0" ToolTip="Rafraîchir la liste des ports" />
                    <Button Content="Connecter" Style="{StaticResource AccentButtonStyle}" Command="{Binding ConnectCommand}"
                            Visibility="{Binding Connected, Converter={StaticResource BoolToVisConv}, ConverterParameter=Invert}" />
                    <Button Content="Déconnecter" Style="{StaticResource AccentButtonStyle}" Command="{Binding DisconnectCommand}"
                            Visibility="{Binding Connected, Converter={StaticResource BoolToVisConv}}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.55*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <views:DroidsCardView Grid.Row="0" Grid.RowSpan="2" Grid.Column="0" DataContext="{Binding Droids}" Margin="0,0,12,14" />
                <views:CalibrationCardView Grid.Row="0" Grid.Column="1" DataContext="{Binding Calibration}" Margin="0,0,0,14" />
                <views:MeshTopologyCardView Grid.Row="1" Grid.Column="1" DataContext="{Binding Topology}" Margin="0,0,0,14" />

                <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <views:AnimationCardView Grid.Column="0" DataContext="{Binding Animation}" Margin="0,0,7,0" />
                    <views:AudioCardView Grid.Column="1" DataContext="{Binding Audio}" Margin="7,0,0,0" />
                </Grid>

                <views:SequencerCardView Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" DataContext="{Binding Sequencer}" />
            </Grid>
        </ScrollViewer>
        </Grid>
    </Grid>
</Window>
