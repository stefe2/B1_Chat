<Window x:Class="b1_chat_console.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:b1_chat_console"
        xmlns:views="clr-namespace:b1_chat_console.Views"
        mc:Ignorable="d"
        Title="B1 Chat — Supervision Console" Height="900" Width="1500"
        Icon="Assets/AppIcon.ico"
        Background="{StaticResource PageBackgroundBrush}">
    <Grid>
        <!-- Diagonal noise texture over the background, across the whole window. -->
        <Rectangle Fill="{StaticResource NoiseTileBrush}" IsHitTestVisible="False" />

        <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header: logo + title, status/port, commit/revert -->
        <Border Grid.Row="0" Background="{StaticResource Bg2Brush}" BorderBrush="{StaticResource BevelBorderBrush}" BorderThickness="0,0,0,1.5" Padding="18,4">
            <Border.Effect>
                <DropShadowEffect Color="Black" Direction="270" ShadowDepth="3" BlurRadius="8" Opacity="0.4" />
            </Border.Effect>
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <Border Style="{StaticResource AppLogoStyle}" Background="Transparent" Width="50" Height="50" Margin="0,0,10,0">
                        <Image Source="Assets/AppLogo.png" Width="50" Height="50" Stretch="Uniform" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="B1 CHAT" Style="{StaticResource PageTitleStyle}" />
                        <TextBlock Text="{Binding VersionSubtitle}" Style="{StaticResource MetaTextStyle}" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <!-- Cluster 1: commit/sync status (always on once the firmware supports it) -->
                    <Border Style="{Binding Protocol.Dirty, Converter={StaticResource BoolToStyleConv}, ConverterParameter='HaloBadgeWarnStyle|HaloBadgeOkStyle'}"
                            Effect="{x:Null}"
                            Visibility="{Binding ShowSyncBadge, Converter={StaticResource BoolToVisConv}}" Margin="0,0,20,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Protocol.Dirty, Converter={StaticResource BoolToTextConv}, ConverterParameter='● unsaved|● synced'}" FontSize="11" Foreground="White" />
                    </Border>

                    <Border Width="1" Height="20" Background="{StaticResource BevelBorderBrush}" Margin="0,0,16,0" VerticalAlignment="Center" />

                    <!-- Cluster 2: manual/dev firmware entry point (always available, unlike the
                         per-droid row buttons which hide once a droid is confirmed up to date). -->
                    <Border Style="{StaticResource HaloBadgeOkStyle}"
                            Visibility="{Binding HasAnyUpdateAvailable, Converter={StaticResource BoolToVisConv}}"
                            Margin="0,0,16,0" VerticalAlignment="Center"
                            ToolTip="{Binding Firmware.UpdateStatus}">
                        <TextBlock Text="● update available" FontSize="11" Foreground="White" />
                    </Border>
                    <Button Style="{StaticResource MiniButtonStyle}" Click="OpenFirmwareWindow_Click"
                            Margin="0,0,8,0" VerticalAlignment="Center" ToolTip="Open the firmware flash and update window">
                        <StackPanel Orientation="Horizontal">
                            <Canvas Width="13" Height="13" Margin="0,0,6,0" VerticalAlignment="Center">
                                <Rectangle Canvas.Left="3" Canvas.Top="3" Width="7" Height="7" RadiusX="1" RadiusY="1" Stroke="{StaticResource AccentBrush}" StrokeThickness="1.2" />
                                <Line X1="5" Y1="0" X2="5" Y2="3" Stroke="{StaticResource AccentBrush}" StrokeThickness="1.2" />
                                <Line X1="8" Y1="0" X2="8" Y2="3" Stroke="{StaticResource AccentBrush}" StrokeThickness="1.2" />
                                <Line X1="5" Y1="10" X2="5" Y2="13" Stroke="{StaticResource AccentBrush}" StrokeThickness="1.2" />
                                <Line X1="8" Y1="10" X2="8" Y2="13" Stroke="{StaticResource AccentBrush}" StrokeThickness="1.2" />
                                <Line X1="0" Y1="5" X2="3" Y2="5" Stroke="{StaticResource AccentBrush}" StrokeThickness="1.2" />
                                <Line X1="10" Y1="5" X2="13" Y2="5" Stroke="{StaticResource AccentBrush}" StrokeThickness="1.2" />
                            </Canvas>
                            <TextBlock Text="Firmware…" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource MiniButtonStyle}" Click="OpenHelpWindow_Click"
                            Margin="0,0,16,0" VerticalAlignment="Center" ToolTip="Open the Help window"
                            AutomationProperties.Name="Help">
                        <StackPanel Orientation="Horizontal">
                            <Grid Width="13" Height="13" Margin="0,0,6,0" VerticalAlignment="Center">
                                <Ellipse Stroke="{StaticResource AccentBrush}" StrokeThickness="1.2" />
                                <TextBlock Text="?" FontSize="9" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-1,0,0" />
                            </Grid>
                            <TextBlock Text="Help" />
                        </StackPanel>
                    </Button>

                    <Border Width="1" Height="20" Background="{StaticResource BevelBorderBrush}" Margin="0,0,16,0" VerticalAlignment="Center" />

                    <!-- Cluster 3: serial connection -->
                    <Border Style="{StaticResource HeaderPillStyle}" Margin="0,0,12,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Style="{Binding Connected, Converter={StaticResource BoolToStyleConv}, ConverterParameter='LedDotOnStyle|LedDotOffStyle'}"
                                     VerticalAlignment="Center" Margin="0,0,7,0" />
                            <TextBlock Text="{Binding ConnectionStatusText}" Foreground="{StaticResource TextBrush}" FontSize="11" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <ComboBox Width="100" Style="{StaticResource DarkComboBoxStyle}" Padding="10,4" FontSize="11" VerticalAlignment="Center" ItemsSource="{Binding AvailablePorts}" SelectedItem="{Binding SelectedPort}" Margin="0,0,6,0" />
                    <Button Content="Rescan" Style="{StaticResource MiniButtonStyle}" Command="{Binding RefreshPortsCommand}" Margin="0,0,8,0" VerticalAlignment="Center" ToolTip="Refresh the port list" />
                    <Button Content="Connect" Style="{StaticResource AccentButtonStyle}" Command="{Binding ConnectCommand}" VerticalAlignment="Center"
                            Visibility="{Binding Connected, Converter={StaticResource BoolToVisConv}, ConverterParameter=Invert}" />
                    <Button Content="Disconnect" Style="{StaticResource AccentButtonStyle}" Command="{Binding DisconnectCommand}" VerticalAlignment="Center"
                            Visibility="{Binding Connected, Converter={StaticResource BoolToVisConv}}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <ScrollViewer x:Name="MainScroll" Grid.Row="1" VerticalScrollBarVisibility="Auto" PreviewMouseWheel="MainScroll_PreviewMouseWheel">
            <Grid Margin="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <views:DroidsCardView Grid.Row="0" Grid.Column="0" DataContext="{Binding Droids}" Margin="0,0,12,14" />
                <views:MeshTopologyCardView Grid.Row="0" Grid.Column="1" DataContext="{Binding Topology}" Margin="0,0,0,14" />

                <views:AnimationCardView Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" DataContext="{Binding Animation}" Margin="0,0,0,14" />

                <views:SequencerCardView Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" DataContext="{Binding Sequencer}" />
            </Grid>
        </ScrollViewer>
        </Grid>
    </Grid>
</Window>
