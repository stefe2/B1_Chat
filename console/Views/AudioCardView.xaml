<UserControl x:Class="b1_chat_console.Views.AudioCardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource CardBorderStyle}">
        <StackPanel>
            <TextBlock Text="AUDIO (MASTER)" Style="{StaticResource CardTitleStyle}" />

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="65" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="VOLUME" Style="{StaticResource FieldLabelStyle}" />
                <Slider Grid.Column="1" Style="{StaticResource MetalSliderStyle}" Minimum="0" Maximum="30" Value="{Binding Volume}" Margin="6,0" />
                <Border Grid.Column="2" Style="{StaticResource ValuePillStyle}"><TextBlock Text="{Binding Volume}" Style="{StaticResource ValuePillTextStyle}" /></Border>
            </Grid>

            <TextBlock Text="TEST TRACK" Style="{StaticResource FieldLabelStyle}" Margin="0,0,0,4" />
            <StackPanel Orientation="Horizontal">
                <TextBox Width="50" Style="{StaticResource RecessedTextBoxStyle}" Text="{Binding Track}" Margin="0,0,8,0" />
                <Button Content="Test" Style="{StaticResource MiniButtonStyle}" Command="{Binding PlayTrackCommand}" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
