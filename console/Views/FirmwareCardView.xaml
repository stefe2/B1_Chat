<UserControl x:Class="b1_chat_console.Views.FirmwareCardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource CardBorderStyle}">
        <StackPanel>
            <TextBlock Text="FIRMWARE (MASTER)" Style="{StaticResource CardTitleStyle}" />

            <TextBlock Text="ROLE TO FLASH" Style="{StaticResource FieldLabelStyle}" Margin="0,0,0,4" />
            <UniformGrid Rows="1" Columns="2" Margin="0,0,0,10">
                <ToggleButton Content="Master" Style="{StaticResource HaloToggleButtonStyle}"
                              IsChecked="{Binding IsMasterRole, Mode=OneWay}" Command="{Binding SelectMasterRoleCommand}" Margin="0,0,4,0" />
                <ToggleButton Content="Slave" Style="{StaticResource HaloToggleButtonStyle}"
                              IsChecked="{Binding IsSlaveRole, Mode=OneWay}" Command="{Binding SelectSlaveRoleCommand}" Margin="4,0,0,0" />
            </UniformGrid>

            <TextBlock Text="FLASH PORT" Style="{StaticResource FieldLabelStyle}" Margin="0,0,0,4" />
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <ComboBox Width="120" Style="{StaticResource DarkComboBoxStyle}" ItemsSource="{Binding AvailablePorts}"
                          SelectedItem="{Binding SelectedFlashPort}" Margin="0,0,6,0" />
                <Button Content="Rescan" Style="{StaticResource MiniButtonStyle}" Command="{Binding RefreshFlashPortsCommand}"
                        ToolTip="Independent of the port connected in the main window — pick any plugged-in ESP32 board, even one never connected." />
            </StackPanel>

            <TextBlock Text="BINARY SOURCE" Style="{StaticResource FieldLabelStyle}" Margin="0,0,0,4" />
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Button Content="From GitHub" Style="{StaticResource MiniButtonStyle}" Command="{Binding PrepareFromGithubCommand}" Margin="0,0,8,0"
                        ToolTip="Downloads and verifies (SHA-256) the latest release for the role selected above, plus the shared bootloader + partition table so a fresh board can be fully flashed." />
                <Button Content="Local file…" Style="{StaticResource MiniButtonStyle}" Command="{Binding PickBinCommand}"
                        ToolTip="Pick any .bin (e.g. a local pio run build) — unverified. If bootloader.bin + partitions.bin sit beside it, a full flash (fresh-board OK) is armed automatically." />
            </StackPanel>

            <Border Background="{StaticResource RecessBrush}" CornerRadius="4" Padding="8,6" Margin="0,0,0,8">
                <TextBlock Text="{Binding ReadyStatus}" FontSize="11" TextWrapping="Wrap"
                           Foreground="{Binding BinVerified, Converter={StaticResource BoolToBrushConv}, ConverterParameter='OkBrush|MutedBrush'}" />
            </Border>

            <Button Content="Advanced options" Style="{StaticResource MiniButtonStyle}" Command="{Binding ToggleAdvancedCommand}"
                    HorizontalAlignment="Left" Margin="0,0,0,6" />
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8" Visibility="{Binding ShowAdvanced, Converter={StaticResource BoolToVisConv}}">
                <TextBlock Text="Address " VerticalAlignment="Center" FontSize="11" />
                <TextBox Width="90" Style="{StaticResource RecessedTextBoxStyle}" Text="{Binding Address}" Margin="4,0,0,0" />
            </StackPanel>

            <Border Background="{StaticResource RecessBrush}" CornerRadius="4" Padding="10,8" Margin="0,0,0,10"
                    BorderBrush="{StaticResource WarnBrush}" BorderThickness="1">
                <StackPanel>
                    <CheckBox Content="Fully erase the chip before flashing" Style="{StaticResource DangerCheckBoxStyle}"
                              IsChecked="{Binding EraseChipFirst}" />
                    <TextBlock Style="{StaticResource HintTextStyle}" TextWrapping="Wrap" Margin="24,4,0,0"
                               Text="Also erases all saved settings (NVS) — irreversible. A normal flash never touches this." />
                </StackPanel>
            </Border>

            <Button Content="{Binding FlashLabel}" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding FlashCommand}"
                    IsEnabled="{Binding CanFlash}" HorizontalAlignment="Left" Margin="0,0,0,10" />

            <StackPanel Margin="0,0,0,10" Visibility="{Binding Flashing, Converter={StaticResource BoolToVisConv}}">
                <ProgressBar Minimum="0" Maximum="100" Value="{Binding FlashProgressPct, Mode=OneWay}"
                             IsIndeterminate="{Binding FlashProgressIndeterminate}" Height="10" />
                <TextBlock Text="{Binding FlashProgressPct, StringFormat='{}{0}%'}" FontSize="10.5"
                           Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Right" Margin="0,2,0,0"
                           Visibility="{Binding FlashProgressIndeterminate, Converter={StaticResource BoolToVisConv}, ConverterParameter=Invert}" />
            </StackPanel>

            <Border Background="{StaticResource RecessBrush}" CornerRadius="4" Padding="6" Margin="0,0,0,12">
                <ScrollViewer x:Name="FlashLogScroll" Height="150" VerticalScrollBarVisibility="Auto" ScrollChanged="FlashLogScroll_ScrollChanged">
                    <ItemsControl ItemsSource="{Binding FlashLog}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontFamily="{StaticResource MonoFont}" FontSize="10" Foreground="{StaticResource TextBrush}" TextWrapping="Wrap" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <Separator Margin="0,0,0,8" />
            <TextBlock Text="UPDATES (GITHUB)" Style="{StaticResource SectionSubtitleStyle}" FontSize="13" />
            <TextBlock Text="{Binding UpdateStatus}" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,0,0,6" />
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4" Visibility="{Binding HasAppUpdate, Converter={StaticResource BoolToVisConv}}">
                <TextBlock Text="App: " FontSize="11" />
                <TextBlock Text="{Binding AppLatest, StringFormat='v{0} available'}" FontSize="11" Foreground="{StaticResource OkBrush}" Margin="0,0,8,0" />
                <Button Content="Install" Style="{StaticResource MiniButtonStyle}" Command="{Binding InstallAppUpdateCommand}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Visibility="{Binding HasFwUpdate, Converter={StaticResource BoolToVisConv}}">
                <TextBlock Text="Firmware: " FontSize="11" />
                <TextBlock Text="{Binding FwLatest, StringFormat='v{0} available (master + slave)'}" FontSize="11" Foreground="{StaticResource OkBrush}" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
