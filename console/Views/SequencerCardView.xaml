<UserControl x:Class="b1_chat_console.Views.SequencerCardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:b1_chat_console.Views">
    <Border Style="{StaticResource CardBorderStyle}">
        <StackPanel>
            <TextBlock Text="ANIMATION SEQUENCER" Style="{StaticResource CardTitleStyle}" />

            <TextBlock Text="CATALOG (8 ESP32 SLOTS)" Style="{StaticResource SectionSubtitleStyle}" />
            <ItemsControl ItemsSource="{Binding Catalog}" Margin="0,0,0,10">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="{StaticResource BorderLoBrush}" BorderThickness="0,0,0,1" Padding="0,4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="60" />
                                    <ColumnDefinition Width="60" />
                                    <ColumnDefinition Width="70" />
                                    <ColumnDefinition Width="70" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="{Binding StepCount, StringFormat='{}{0} steps'}" FontSize="10" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" Text="{Binding Loop, StringFormat='loop:{0}'}" FontSize="10" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" />
                                <Button Grid.Column="3" Content="Load" Style="{StaticResource MiniButtonStyle}"
                                        Command="{Binding DataContext.LoadSlotCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}" Margin="0,0,4,0" />
                                <Button Grid.Column="4" Content="Del." Style="{StaticResource MiniButtonStyle}"
                                        Command="{Binding DataContext.DeleteSlotCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Separator Margin="0,0,0,8" />

            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Style="{StaticResource RecessedTextBoxStyle}" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0" />
                <CheckBox Grid.Column="1" Content="Loop" IsChecked="{Binding Loop}" VerticalAlignment="Center" />
            </Grid>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Button Content="Undo" Style="{StaticResource MiniButtonStyle}" Command="{Binding UndoCommand}" Margin="0,0,4,0" />
                <Button Content="Redo" Style="{StaticResource MiniButtonStyle}" Command="{Binding RedoCommand}" Margin="0,0,4,0" />
                <Button Content="New" Style="{StaticResource MiniButtonStyle}" Command="{Binding NewSequenceCommand}" Margin="0,0,4,0" />
                <Button Content="Save (ESP32)" Style="{StaticResource MiniButtonStyle}" Command="{Binding SaveToSlotCommand}" Margin="0,0,4,0" />
                <Button Content="→ Library" Style="{StaticResource MiniButtonStyle}" Command="{Binding SaveToLibraryCommand}" />
            </StackPanel>

            <views:SequenceTimelineView Margin="0,0,0,10" />

            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Button Content="Play" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding PlayCommand}" Margin="0,0,4,0" />
                <Button Content="Stop" Style="{StaticResource MiniButtonStyle}" Command="{Binding StopCommand}" Margin="0,0,4,0" />
                <Button Content="Pause" Style="{StaticResource MiniButtonStyle}" Command="{Binding PauseCommand}" Margin="0,0,4,0" />
                <Button Content="Resume" Style="{StaticResource MiniButtonStyle}" Command="{Binding ResumeCommand}" Margin="0,0,4,0" />
                <Button Style="{StaticResource MiniButtonStyle}" Command="{Binding ToggleRehearsalCommand}">
                    <TextBlock Text="{Binding IsRehearsing, Converter={StaticResource BoolToTextConv}, ConverterParameter='Stop rehearsal|Rehearse (local)'}" />
                </Button>
                <Button Content="Export" Style="{StaticResource MiniButtonStyle}" Command="{Binding ExportCommand}" Margin="8,0,4,0" />
                <Button Content="Import" Style="{StaticResource MiniButtonStyle}" Command="{Binding ImportCommand}" />
            </StackPanel>

            <Separator Margin="0,0,0,8" />
            <TextBlock Text="LOCAL LIBRARY" Style="{StaticResource SectionSubtitleStyle}" />
            <ItemsControl ItemsSource="{Binding Library}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="{StaticResource BorderLoBrush}" BorderThickness="0,0,0,1" Padding="0,4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="70" />
                                    <ColumnDefinition Width="70" />
                                    <ColumnDefinition Width="70" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center" />
                                <Button Grid.Column="1" Content="Load" Style="{StaticResource MiniButtonStyle}"
                                        Command="{Binding DataContext.LoadFromLibraryCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}" Margin="0,0,4,0" />
                                <Button Grid.Column="2" Content="→ ESP32" Style="{StaticResource MiniButtonStyle}"
                                        Command="{Binding DataContext.PushToMasterCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}" Margin="0,0,4,0" />
                                <Button Grid.Column="3" Content="Del." Style="{StaticResource MiniButtonStyle}"
                                        Command="{Binding DataContext.DeleteFromLibraryCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Border>
</UserControl>
