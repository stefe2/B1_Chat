<UserControl x:Class="b1_chat_console.Views.SequencerCardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:b1_chat_console.Views">
    <Border Style="{StaticResource CardBorderStyle}">
        <StackPanel>
            <DockPanel LastChildFill="False" Margin="0,0,0,12">
                <Border Style="{StaticResource CardIconBoxStyle}" DockPanel.Dock="Left" Margin="0,0,10,0">
                    <Canvas Width="15" Height="15">
                        <Rectangle Canvas.Left="0" Canvas.Top="1" Width="10" Height="2.6" RadiusX="1.3" RadiusY="1.3" Stroke="{StaticResource AccentBrush}" StrokeThickness="1.3" />
                        <Rectangle Canvas.Left="0" Canvas.Top="6" Width="15" Height="2.6" RadiusX="1.3" RadiusY="1.3" Stroke="{StaticResource AccentBrush}" StrokeThickness="1.3" />
                        <Rectangle Canvas.Left="0" Canvas.Top="11" Width="7" Height="2.6" RadiusX="1.3" RadiusY="1.3" Stroke="{StaticResource AccentBrush}" StrokeThickness="1.3" />
                    </Canvas>
                </Border>
                <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                    <TextBlock Text="ANIMATION SEQUENCER" Style="{StaticResource CardTitleStyle}" FontSize="13" Margin="0" />
                    <TextBlock Text="Multi-track timeline — parallel per-droid lanes, absolute start times"
                               Style="{StaticResource MetaTextStyle}" Margin="0,1,0,0" />
                </StackPanel>
                <Border DockPanel.Dock="Right" Style="{StaticResource ValuePillStyle}" VerticalAlignment="Center" MinWidth="0">
                    <TextBlock Text="{Binding SequenceBadgeText}" Style="{StaticResource ValuePillTextStyle}" FontSize="10.5" />
                </Border>
            </DockPanel>

            <!-- The ESP32 slot catalog UI was removed on request (2026-07-16) — the master's 8
                 NVS slots still exist firmware-side and are still reachable through the Local
                 Library's "→ ESP32" push; the VM's Catalog/LoadSlot/DeleteSlot plumbing stays. -->

            <!-- Name field + New/"→ Library" buttons removed on request (2026-07-16) — Clear
                 (transport bar) empties the editor, and sequence names now only come from a
                 loaded/imported file. Play/Stop/Pause/Resume/Loop/Undo/Redo/Export/Import/
                 Clear/zoom/snap all live in SequenceTimelineView's own transport bar. -->
            <views:SequenceTimelineView Margin="0,0,0,10" />

            <Separator Margin="0,0,0,8" />
            <TextBlock Text="LOCAL LIBRARY" Style="{StaticResource SectionSubtitleStyle}" />
            <ItemsControl ItemsSource="{Binding Library}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="{StaticResource BorderLoBrush}" BorderThickness="0,0,0,1" Padding="0,4">
                            <!-- "→ ESP32" removed with the rest of the slot machinery (fw 1.7.0):
                                 the console no longer writes the master's sequence slots at all. -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="70" />
                                    <ColumnDefinition Width="70" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center" />
                                <Button Grid.Column="1" Content="Load" Style="{StaticResource MiniButtonStyle}"
                                        Command="{Binding DataContext.LoadFromLibraryCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}" Margin="0,0,4,0" />
                                <Button Grid.Column="2" Content="Del." Style="{StaticResource MiniButtonStyle}"
                                        Command="{Binding DataContext.DeleteFromLibraryCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Border>
</UserControl>
